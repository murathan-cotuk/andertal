# Copy to `.env` or `.env.local` in this folder (`apps/medusa-backend`).
# `server.js` loads both via dotenv.

# ── Shop URL for Flow emails (ORDER_DETAIL_URL, MY_ORDERS_URL, …) ──
# Must be absolute HTTPS URL (no trailing slash). Render backend usually does not inherit Vercel env —
# set this here explicitly. Aliases also read: SHOP_PUBLIC_URL, PUBLIC_SHOP_URL, NEXT_PUBLIC_SITE_URL, SITE_URL.
# STOREFRONT_PUBLIC_URL=https://www.andertal.com

# ── DeepL — automatic translation (Seller Central → Content → Flows → “Translate to other languages”) ──
# Create a key: https://www.deepl.com/pro-api
# Free API keys typically end with `:fx`; the backend then uses api-free.deepl.com unless you override URL below.
DEEPL_AUTH_KEY=

# Optional. Default: https://api.deepl.com/v2/translate (Pro) or https://api-free.deepl.com/v2/translate (free key).
# DEEPL_API_URL=https://api-free.deepl.com/v2/translate
