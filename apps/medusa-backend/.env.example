# Medusa v2 Backend - Örnek env (kopyalayıp .env.local yapın)
# ─────────────────────────────────────────────────────────────────
# PRODUCTION'DA MUTLAKA DEĞİŞTİRİLMESİ ZORUNLU OLAN DEĞİŞKENLER
# SELLER_JWT_SECRET ve CUSTOMER_JWT_SECRET ayarlanmazsa sunucu başlamaz.
# ─────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────
# Yerel PostgreSQL: postgresql://user:password@localhost:5432/medusa
# Render (External): Render dashboard'dan "External Database URL" kopyalayın
DATABASE_URL=postgresql://medusa_user:XXX@dpg-XXXXX.frankfurt-postgres.render.com/medusa_seoj

# ── Server ────────────────────────────────────────────────────────
PORT=9000
HOST=0.0.0.0
NODE_ENV=development
SERVER_URL=http://localhost:9000

# ── CORS (production'da frontend URL'lerini ekleyin) ──────────────
# Virgülle ayırın: shop + sellercentral domain'leri
CORS_ORIGINS=http://localhost:3000,http://localhost:3002
STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:3002

# ── JWT Secrets (PRODUCTION'DA ZORUNLU — ikisi de ayarlanmalı) ───
# Güçlü rastgele değer üretmek için: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
#
# Seller (sellercentral) token'ları için — DEĞİŞTİR:
SELLER_JWT_SECRET=change-me-seller-use-a-long-random-string-in-production

# Customer (shop) token'ları için — DEĞİŞTİR:
CUSTOMER_JWT_SECRET=change-me-customer-use-a-long-random-string-in-production

# Eski tek-secret (artık kullanılmıyor, geriye dönük uyumluluk için bırakıldı):
# JWT_SECRET=...

# Cookie secret (session vb. için)
COOKIE_SECRET=change-me-cookie-secret-in-production

# ── Superuser ─────────────────────────────────────────────────────
# Virgülle ayrılmış e-posta listesi — bu adresler otomatik superuser olur
SUPERUSER_EMAILS=murathan.cotuk@gmail.com

# ── Stripe (checkout için) ────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── AWS S3 (medya upload için, opsiyonel) ─────────────────────────
# S3_UPLOAD_BUCKET=belucha-media
# S3_UPLOAD_REGION=eu-central-1
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...

# ── Email (Resend, opsiyonel) ─────────────────────────────────────
# RESEND_API_KEY=re_...
# EMAIL_FROM=noreply@belucha.de
TOTP_ENCRYPTION_KEY=6d9209046fb98dd6148c9d3f5ad6a6cdf3151bfce5b664156ad91c048e9a75de