# Medusa Backend URL — sellercentral API çağrıları (POST /admin-hub/v1/pages vb.)
# apps/shop ile aynı URL olmalı; aksi halde landing / menü bir app’te kayıtlı diğerinde boş kalır.
#
# Yerel Medusa çalıştırıyorsan:
# NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
#
# .env.local yoksa veya boşsa kod şu adresi kullanır:
# https://andertal-medusa-backend.onrender.com
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://api.andertal.com

# DeepL (Flow “Translate to other languages”) is configured on the Medusa backend only:
# apps/medusa-backend/.env → DEEPL_AUTH_KEY (see apps/medusa-backend/.env.example).