# Medusa Backend URL (shop bu API'ye bağlanır).
# Seller Central ile AYNI adres olmalı; yoksa menü/landing değişiklikleri birbirini görmez.
# Yerel Medusa: http://localhost:9000  (medusa-backend çalışırken)
# Render: https://belucha-medusa-backend.onrender.com
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://belucha-medusa-backend.onrender.com
# Önemli (localhost): Shop tarayıcıda localhost/127.0.0.1 açıkken, bu "true" DEĞİLSE
# NEXT_PUBLIC_MEDUSA_BACKEND_URL yok sayılır ve daima http://localhost:9000 kullanılır.
# Seller Central ise daima yukarıdaki URL'ye gider. İkisi aynı veritabanı olmalı: ya ikisi
# de localhost:9000 (medusa local çalışsın), ya da aşağıyı true yapıp ikisi de aynı uzak URL.
NEXT_PUBLIC_MEDUSA_USE_ENV_IN_DEV=true
NEXT_PUBLIC_FREE_SHIPPING_THRESHOLD_CENTS=5000

# Tarayıcı sekmesi / OG başlığında "Site adı | …" için (opsiyonel; yoksa SITE_URL host veya Belucha)
# NEXT_PUBLIC_SITE_NAME=Belucha

# Seller Central URL (Footer vb. satıcı girişi linki)
NEXT_PUBLIC_SELLERCENTRAL_URL=https://belucha-sellercentral.vercel.app

# Stripe (checkout için)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Algolia (ürün arama dropdown için - opsiyonel)
# NEXT_PUBLIC_ALGOLIA_APP_ID=
# NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=
# NEXT_PUBLIC_ALGOLIA_INDEX_PRODUCTS=
