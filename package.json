{
  "name": "andertal",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "render:install-backend": "cross-env NODE_OPTIONS=--max-old-space-size=8192 npm install --omit=dev --no-audit --no-fund && node apps/medusa-backend/scripts/patch-link-modules.js",
    "build": "turbo run build",
    "dev": "turbo run dev --continue=always",
    "dev:web": "turbo run dev --filter=@andertal/sellercentral --filter=@andertal/shop",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{js,jsx,md}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "postinstall": "patch-package || true",
    "patch:backend": "node apps/medusa-backend/scripts/patch-link-modules.js",
    "start": "node apps/medusa-backend/server.js",
    "storybook": "npm run storybook --workspace=packages/ui",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@opentelemetry/sdk-trace-base": "^1.28.0",
    "@sentry/nextjs": "^10.43.0",
    "better-sqlite3": "^12.6.2",
    "cross-env": "^7.0.3",
    "dotenv": "^17.2.3",
    "medusa": "^0.0.3",
    "next": "16.0.10",
    "patch-package": "^8.0.1",
    "pg": "^8.18.0",
    "scheduler": "^0.27.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@turbo/gen": "^2.6.1",
    "prettier": "^3.0.0",
    "turbo": "^2.9.4",
    "wrangler": "^3.94.0"
  },
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*",
    "apps/medusa-backend"
  ],
  "overrides": {
    "esbuild": "^0.25.0",
    "tmp": "^0.2.3",
    "@esbuild-kit/core-utils": {
      "esbuild": "^0.25.0"
    },
    "drizzle-kit": {
      "@esbuild-kit/esm-loader": {
        "@esbuild-kit/core-utils": {
          "esbuild": "^0.25.0"
        }
      }
    }
  }
}
